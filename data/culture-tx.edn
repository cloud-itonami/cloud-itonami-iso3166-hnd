#:culture{:id "hnd.dish.baleada", :name "Baleada", :country "HND", :kind :dish, :summary "Traditional Honduran dish originating from the northern coast, particularly La Ceiba: a flour tortilla filled with a smear of mashed refried red beans, crema and crumbled queso duro.", :url "https://en.wikipedia.org/wiki/Baleada", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hnd.dish.sopa-de-caracol", :name "Sopa de caracol", :country "HND", :kind :dish, :summary "Honduran conch soup in which the conch is cooked in coconut milk and the conch's broth, with spices, yuca, cilantro and green bananas known as guineo verde.", :url "https://en.wikipedia.org/wiki/Honduran_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hnd.dish.carneada", :name "Carneada", :country "HND", :kind :dish, :summary "One of Honduras' national dishes: grilled beef marinated in sour orange juice and spices, served with chismol salsa and plantains.", :url "https://en.wikipedia.org/wiki/Honduran_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hnd.dish.sopa-de-frijoles", :name "Sopa de frijoles", :country "HND", :kind :dish, :summary "Traditional Honduran bean soup of black or red beans boiled with garlic, blended and combined with pork-bone broth.", :url "https://en.wikipedia.org/wiki/Honduran_cuisine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hnd.product.coffee", :name "Honduran coffee", :country "HND", :kind :product, :summary "Honduras transitioned from minimal coffee exportation in the 1890s to becoming Central America's top coffee producer in 2011.", :url "https://en.wikipedia.org/wiki/Coffee_production_in_Honduras", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hnd.festival.la-ceiba-carnival", :name "La Ceiba Carnival", :country "HND", :kind :festival, :summary "Annual celebration held in La Ceiba, Honduras, on the third or fourth Saturday of May, honouring Saint Isidore the Laborer with parades and neighbourhood festivities attracting over 500,000 visitors.", :url "https://en.wikipedia.org/wiki/La_Ceiba_Carnival", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "hnd.heritage.copan", :name "Copán", :country "HND", :kind :heritage, :summary "Archaeological site of the Maya civilisation in western Honduras near the Guatemala border, designated a UNESCO World Heritage Site in 1980.", :url "https://en.wikipedia.org/wiki/Cop%C3%A1n", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
